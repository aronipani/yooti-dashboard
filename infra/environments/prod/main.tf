# Prod environment — wires all modules together.
# Module calls added after dev environment is validated.

terraform {
  required_version = ">= 1.7.0"

  required_providers {
    aws = {
      source  = "hashicorp/aws"
      version = "~> 5.0"
    }
  }
}

provider "aws" {
  region = var.aws_region

  default_tags {
    tags = {
      Project     = var.project
      Environment = var.environment
      ManagedBy   = "terraform"
    }
  }
}

# Module calls will mirror dev after validation.
# VPC module intentionally not wired — reserved for future use.
