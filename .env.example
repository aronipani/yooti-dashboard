# ══════════════════════════════════════════════
# Yooti project environment variables
# Copy this file to .env and fill in all values
# Never commit .env to git
# ══════════════════════════════════════════════

# ── APPLICATION ──────────────────────────────
NODE_ENV=development
PORT=3000
LOG_LEVEL=info

# ── SECURITY ──────────────────────────────────
JWT_SECRET=replace-with-a-long-random-string-min-32-chars
JWT_EXPIRY=24h
REFRESH_TOKEN_SECRET=replace-with-a-different-long-random-string
REFRESH_TOKEN_EXPIRY=7d
BCRYPT_COST=12

# ── DATABASE ──────────────────────────────────
DATABASE_URL=postgresql://app:app@localhost:5432/appdb
DATABASE_POOL_SIZE=10

# ── CACHE ─────────────────────────────────────
REDIS_URL=redis://localhost:6379
REDIS_TTL_SECONDS=3600
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# ── LLM PROVIDERS ────────────────────────────
ANTHROPIC_API_KEY=your-anthropic-api-key-here
ANTHROPIC_MODEL=claude-sonnet-4-5-20251001

# ── LANGSMITH OBSERVABILITY ──────────────────
LANGCHAIN_TRACING_V2=true
LANGCHAIN_API_KEY=your-langsmith-api-key-here
LANGCHAIN_PROJECT=yooti-dashboard

# ── AWS ───────────────────────────────────────
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your-access-key-id
AWS_SECRET_ACCESS_KEY=your-secret-access-key
AWS_DEFAULT_REGION=us-east-1
AWS_ENDPOINT_URL=http://localhost:4566
S3_BUCKET=your-bucket-name
S3_PREFIX=uploads/

# ── DYNAMODB / DASHBOARD ────────────────────
TABLE_NAME=yooti-metrics
YOOTI_DASHBOARD_API_URL=http://localhost:4566/restapis/local/local/_user_request_
YOOTI_DASHBOARD_API_KEY=

# ── FRONTEND ──────────────────────────────────
VITE_API_URL=http://localhost:3000
VITE_API_BASE_URL=/api
VITE_PROJECT_ID=yooti-ri
NEXT_PUBLIC_API_URL=http://localhost:3000
VITE_APP_NAME=yooti-dashboard

# ── EMAIL ─────────────────────────────────────
SENDGRID_API_KEY=your-sendgrid-api-key
EMAIL_FROM=noreply@yourdomain.com
EMAIL_FROM_NAME=yooti-dashboard

# ── MONITORING ────────────────────────────────
SNYK_TOKEN=your-snyk-token-for-ci

# Agents
# LLM Providers
ANTHROPIC_API_KEY=your-key-here


# LangSmith (observability — get key at smith.langchain.com)
LANGCHAIN_TRACING_V2=true
LANGCHAIN_API_KEY=your-langsmith-key
LANGCHAIN_PROJECT=yooti-dashboard

# Vector store



# Agent config
AGENT_MAX_ITERATIONS=10
AGENT_TEMPERATURE=0
